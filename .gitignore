# Dependencies
node_modules/

# Local DVNA clone (benchmark); clone with: git clone https://github.com/appsecco/dvna dvna
dvna/

# DVNA under benchmarks layout (see benchmarks/dvna/README.md)
benchmarks/dvna/dvna/

# Optional second benchmark corpus (see docs/vibescan/BENCHMARK-SECOND-CORPUS.md)
benchmarks/nodegoat/NodeGoat/

# Build output (push source only)
dist/

# Environment and secrets
.env
.env.local
.env.*.local
*.pem

# Logs and runtime
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS and IDE
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.sublime-*

# Test and coverage
coverage/
.nyc_output/

# Optional
.cache/

# CodeQL CLI bundle and zip (see benchmarks/scripts/run-codeql-dvna.ps1)
benchmarks/.cache/

# CodeQL databases are large; keep committed SARIF + manifests. Regenerate DB with benchmarks/scripts/run-codeql-dvna.ps1
benchmarks/results/**/codeql-db/

# BEGIN secure-arch generated ignores (extra key material; .env already above)
!.env.example
*.key
*.p12
# END secure-arch generated ignores
