# Dependencies
node_modules/

# Local DVNA clone (benchmark); clone with: git clone https://github.com/appsecco/dvna dvna
dvna/

# DVNA under benchmarks layout (see benchmarks/dvna/README.md)
benchmarks/dvna/dvna/

# Build output (push source only). Scanner output is vibescan/dist/; do not resurrect repo-root dist/.
dist/

# Environment and secrets
.env
.env.local
.env.*.local
*.pem

# Logs and runtime
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS and IDE
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.sublime-*

# Test and coverage
coverage/
.nyc_output/

# Optional
.cache/

# BEGIN secure-arch generated ignores (extra key material; .env already above)
!.env.example
*.key
*.p12
# END secure-arch generated ignores
