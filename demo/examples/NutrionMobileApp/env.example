# ============================================
# Nutrition Mobile App - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Database Configuration
# ============================================
# Development (H2 in-memory - default)
# No configuration needed for H2

# Production (PostgreSQL)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/nutrition_db
SPRING_DATASOURCE_USERNAME=nutrition_user
SPRING_DATASOURCE_PASSWORD=your_secure_password_here

# ============================================
# Redis Configuration (Optional)
# ============================================
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
# SPRING_DATA_REDIS_PASSWORD=  # Optional

# ============================================
# Authentication Configuration
# ============================================

# Auth0 (Recommended for production)
# Backend Configuration
AUTH0_ENABLED=false
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id_here
AUTH0_CLIENT_SECRET=your_client_secret_here
AUTH0_AUDIENCE=https://your-api-identifier
AUTH0_ISSUER=https://your-tenant.auth0.com/

# Frontend Configuration (for Flutter app)
# These can be set via environment variables when building the Flutter app
# Example: flutter run --dart-define=AUTH0_DOMAIN=your-tenant.auth0.com --dart-define=AUTH0_CLIENT_ID=your_client_id --dart-define=AUTH0_AUDIENCE=https://your-api-identifier
# Or set in app_config.dart directly for development

# JWT (Fallback if Auth0 not enabled)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRATION=86400000  # 24 hours in milliseconds

# ============================================
# ML/AI Configuration
# ============================================

# ML Mode: "local" (use local ONNX model) or "openrouter-only" (use only OpenRouter)
ML_MODE=local

# ONNX Model Configuration
ONNX_MODEL_NAME=food_classifier.onnx
ML_AUTO_DOWNLOAD=true  # Automatically download model if missing
# ML_MODEL_DOWNLOAD_URL=  # Optional: custom model download URL
# Food-101 model is available at GitHub Releases:
ML_MODEL_DOWNLOAD_URL=https://github.com/Joshober/NutrionMobileApp/releases/download/v1.0.0-food101-model/food101_resnet50.onnx

# OpenRouter Configuration (Optional - for cloud-based food recognition)
OPENROUTER_ENABLED=false
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
OPENROUTER_MODEL=openai/gpt-4o  # or anthropic/claude-3-opus, etc.
USE_OPENROUTER_ONLY=false  # Set to true to use only OpenRouter (no local model)

# ============================================
# Menu Processing Configuration
# ============================================
SODEXO_API_KEY=demo-key  # Replace with real API key if using Sodexo

# ============================================
# Server Configuration
# ============================================
SERVER_PORT=8080

# ============================================
# Flyway (Database Migrations)
# ============================================
FLYWAY_ENABLED=true

# ============================================
# Logging (Optional)
# ============================================
# LOGGING_LEVEL_ROOT=INFO
# LOGGING_LEVEL_COM_NUTRITION=DEBUG

# ============================================
# Docker Configuration (if using Docker Compose)
# ============================================
# These are typically set in docker-compose.yml
# POSTGRES_DB=nutrition_db
# POSTGRES_USER=nutrition_user
# POSTGRES_PASSWORD=nutrition_pass
# REDIS_PASSWORD=  # Optional

# ============================================
# Production Profile Configuration
# ============================================
# Activate production profile
SPRING_PROFILES_ACTIVE=prod

# CORS Configuration (REQUIRED for production)
# Comma-separated list of allowed origins (e.g., https://app.example.com,https://www.example.com)
# DO NOT use wildcards in production!
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Swagger/OpenAPI Configuration
# Set to false to disable Swagger UI in production (recommended)
SWAGGER_ENABLED=false

# Database Connection Pool (Production optimized)
HIKARI_MAX_POOL_SIZE=30
HIKARI_MIN_IDLE=10

# Model Service URL (if using separate model service)
MODEL_SERVICE_URL=http://model-service:8000
ML_MODELS_PATH=/app/models/

# ============================================
# Development vs Production
# ============================================
# For development: Use H2 (no DB config needed), Auth0 disabled, Swagger enabled
# For production: Use PostgreSQL, enable Auth0, set secure JWT secret, restrict CORS

# ============================================
# Quick Start Examples
# ============================================

# Example 1: Local Development (H2 + Local ONNX Model)
# - Leave database vars commented
# - Set AUTH0_ENABLED=false
# - Set ML_MODE=local
# - Set ML_AUTO_DOWNLOAD=true

# Example 2: Production with OpenRouter Only
# - Set PostgreSQL vars
# - Set AUTH0_ENABLED=true and Auth0 vars
# - Set OPENROUTER_ENABLED=true
# - Set USE_OPENROUTER_ONLY=true
# - Set ML_AUTO_DOWNLOAD=false

# Example 3: Production with Local Model
# - Set PostgreSQL vars
# - Set AUTH0_ENABLED=true and Auth0 vars
# - Set ML_MODE=local
# - Set ML_AUTO_DOWNLOAD=false (model should be pre-deployed)
# - Set OPENROUTER_ENABLED=true (for fallback)

# ============================================
# Production Deployment Checklist
# ============================================
# [ ] Set SPRING_PROFILES_ACTIVE=prod
# [ ] Configure CORS_ALLOWED_ORIGINS with your frontend domain(s)
# [ ] Set SWAGGER_ENABLED=false (or secure it with authentication)
# [ ] Set AUTH0_ENABLED=true and configure all Auth0 variables
# [ ] Set secure JWT_SECRET (minimum 32 characters, use strong random string)
# [ ] Set POSTGRES_PASSWORD to a strong password
# [ ] Set OPENROUTER_API_KEY if using OpenRouter
# [ ] Set ML_AUTO_DOWNLOAD=false (pre-deploy models)
# [ ] Verify all environment variables are set correctly
# [ ] Test health check endpoint: /actuator/health
# [ ] Verify CORS is working with your frontend domain
# [ ] Check logs for any errors or warnings

