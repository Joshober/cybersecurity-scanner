{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Joshober/cybersecurity-scanner/docs/vibescan/vibescan-benchmark-output.schema.json",
  "title": "VibeScan project JSON (benchmark-oriented)",
  "description": "Shape emitted by formatProjectJson; optional run{} and summary.findingsPerFile when using --benchmark-metadata or VIBESCAN_BENCHMARK=1.",
  "type": "object",
  "required": ["summary", "findings", "fileResults"],
  "properties": {
    "summary": {
      "type": "object",
      "required": ["totalFindings", "bySeverity", "byRuleId", "byCategory"],
      "properties": {
        "totalFindings": { "type": "integer", "minimum": 0 },
        "bySeverity": {
          "type": "object",
          "properties": {
            "critical": { "type": "integer" },
            "error": { "type": "integer" },
            "warning": { "type": "integer" },
            "info": { "type": "integer" }
          },
          "additionalProperties": false
        },
        "byRuleId": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "byCategory": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "findingsPerFile": {
          "type": "object",
          "description": "Present when benchmark metadata is enabled.",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "proofCoverage": {
          "type": "object",
          "description": "Share of findings by proof tier; always present in project JSON from formatProjectJson.",
          "properties": {
            "total_findings": { "type": "integer", "minimum": 0 },
            "provable": { "type": "integer", "minimum": 0 },
            "partial": { "type": "integer", "minimum": 0 },
            "structural": { "type": "integer", "minimum": 0 },
            "detection_only": { "type": "integer", "minimum": 0 },
            "proof_coverage_percent": { "type": "number" },
            "deterministic_proof_percent": {
              "type": "number",
              "description": "Among findings with wasGenerated proof, share where deterministic is true (0–100)."
            },
            "proof_pipeline_not_run": { "type": "boolean" },
            "by_tier": {
              "type": "object",
              "properties": {
                "tier_1": { "type": "integer" },
                "tier_2": { "type": "integer" },
                "tier_3": { "type": "integer" },
                "tier_4": { "type": "integer" }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "run": {
      "type": "object",
      "description": "Present when --benchmark-metadata or VIBESCAN_BENCHMARK=1.",
      "properties": {
        "toolVersion": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "gitCommit": { "type": ["string", "null"] },
        "scanOptions": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    },
    "routes": { "type": "array" },
    "routeInventory": { "type": "array" },
    "openApiSpecsUsed": { "type": "array", "items": { "type": "string" } },
    "buildId": { "type": "string" },
    "packageJsonPath": { "type": "string" },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "fileResults": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["filePath", "findings"],
        "properties": {
          "filePath": { "type": "string" },
          "file": { "type": "string" },
          "findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
          "routeCount": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "finding": {
      "type": "object",
      "required": ["ruleId", "message", "severity", "severityLabel", "category", "line", "file"],
      "properties": {
        "ruleId": { "type": "string" },
        "ruleFamily": {
          "type": "string",
          "description": "Optional taxonomy label when benchmark metadata enriches findings."
        },
        "message": { "type": "string" },
        "severity": { "type": "string" },
        "severityLabel": { "type": "string" },
        "category": { "type": "string" },
        "line": { "type": "integer" },
        "column": { "type": "integer" },
        "file": { "type": "string" },
        "filePath": { "type": "string" },
        "route": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    }
  }
}
