{
  "name": "secure-code-scanner",
  "version": "1.0.0",
  "description": "VibeScan (secure-code-scanner) — static analysis for crypto failures and injection risks in JavaScript/TypeScript",
  "main": "dist/system/index.js",
  "types": "dist/system/index.d.ts",
  "bin": {
    "secure": "dist/system/cli/index.js",
    "vibescan": "dist/system/cli/index.js"
  },
  "workspaces": [
    "packages/secure-arch-core",
    "packages/secure-arch-adapters",
    "packages/secure-arch-cli"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:scanner": "npm run build",
    "build:arch": "npm run build -w @secure-arch/core -w @secure-arch/adapters -w @secure-arch/cli",
    "build:all": "npm run build && npm run build:arch",
    "test": "npm run build && node --test tests/unit/",
    "test:arch": "npm run build:arch && npm run test -w @secure-arch/core",
    "test:only": "node --test tests/unit/",
    "prepublishOnly": "npm run build",
    "secure-arch": "node packages/secure-arch-cli/dist/cli.js",
    "policy-eval": "node scripts/policy-eval.mjs"
  },
  "keywords": [
    "security",
    "static-analysis",
    "cryptography",
    "injection",
    "eslint-plugin",
    "lint"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@typescript-eslint/parser": "^7.0.0",
    "acorn": "^8.11.0",
    "eslint": ">=8.0.0",
    "fast-glob": "^3.3.0",
    "picomatch": "^4.0.3",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@secure-arch/cli": "file:packages/secure-arch-cli",
    "@types/eslint": "^8.56.0",
    "@types/estree": "^1.0.0",
    "@types/node": "^20.0.0",
    "@types/picomatch": "^4.0.2",
    "eslint-plugin-security": "^2.1.1",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    }
  }
}
