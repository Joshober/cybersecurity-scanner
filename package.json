{
  "name": "cybersecurity-monorepo",
  "private": true,
  "description": "Monorepo: VibeScan (secure-code-scanner) + universal secure-architecture rule system",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build:scanner": "npm run build -w secure-code-scanner",
    "build:arch": "npm run build -w @secure-arch/core -w @secure-arch/adapters -w @secure-arch/cli",
    "secure-arch": "node packages/secure-arch-cli/dist/cli.js"
  },
  "devDependencies": {
    "@secure-arch/cli": "file:packages/secure-arch-cli"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
