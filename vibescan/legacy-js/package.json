{
  "name": "vibescan",
  "version": "0.1.0",
  "description": "Static security scanner for Express/Fastify-style apps: route graph, rules, payloads, slopsquat",
  "type": "module",
  "main": "src/cli.js",
  "bin": {
    "vibescan": "src/cli.js"
  },
  "files": [
    "src",
    "RULES.md",
    "README.md"
  ],
  "scripts": {
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "dev": "nodemon src/cli.js"
  },
  "keywords": [
    "security",
    "static-analysis",
    "express",
    "sast"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@babel/parser": "^7.26.0",
    "@babel/traverse": "^7.26.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0"
  }
}
