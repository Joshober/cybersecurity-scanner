{
  "name": "vibescan",
  "version": "1.0.0",
  "description": "VibeScan — static analysis for crypto failures and injection risks in JavaScript/TypeScript",
  "main": "dist/system/index.js",
  "types": "dist/system/index.d.ts",
  "bin": {
    "secure": "dist/system/cli/index.js",
    "vibescan": "dist/system/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test tests/unit/",
    "release:check": "npm run build && npm pack --dry-run",
    "prepublishOnly": "npm run build",
    "policy-eval": "node scripts/policy-eval.mjs",
    "policy-check": "node scripts/policy-check.mjs"
  },
  "keywords": [
    "security",
    "static-analysis",
    "cryptography",
    "injection",
    "eslint-plugin",
    "lint"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@typescript-eslint/parser": "^7.0.0",
    "acorn": "^8.11.0",
    "eslint": ">=8.0.0",
    "fast-glob": "^3.3.0",
    "picomatch": "^4.0.3",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/eslint": "^8.56.0",
    "@types/estree": "^1.0.0",
    "@types/node": "^20.0.0",
    "@types/picomatch": "^4.0.2",
    "eslint-plugin-security": "^2.1.1",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    }
  }
}

